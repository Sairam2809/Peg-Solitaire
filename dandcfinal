# PegSolitaireApp
# ======================================================================
class PegSolitaireApp:
    def __init__(self, root: tk.Tk):
        self.root = root
        self.root.title("Peg Solitaire \u2014 Divide and Conquer")
        self.root.geometry("800x900")
        self.root.minsize(700,800)
        self.root.configure(bg="#1a2634")
        self.colors = {
            'bg':        '#1a2634',
            'primary':   '#2c3e50',
            'secondary': '#34495e',
            'accent1':   '#e74c3c',
            'accent2':   '#3498db',
            'accent3':   '#2ecc71',
            'text':      '#ecf0f1',
            'highlight': '#f1c40f'
        }
        self.current_frame: Optional[tk.Frame] = None
        self.show_main_menu()
    def clear_window(self) -> None:
        if self.current_frame:
            self.current_frame.destroy()
    def show_main_menu(self) -> None:
        self.clear_window()
        frame = tk.Frame(self.root, bg=self.colors['bg'])
        frame.pack(fill="both", expand=True)
        self.current_frame = frame
        header = tk.Frame(frame, bg=self.colors['bg'])
        header.pack(pady=50)
        tk.Label(header, text="PEG SOLITAIRE",
                 font=("Helvetica", 36, "bold"),
                 bg=self.colors['bg'], fg=self.colors['accent3']).pack()
        tk.Frame(header, height=2, width=400,
                 bg=self.colors['accent1']).pack(pady=20)
        tk.Label(header, text="Algorithmic Approach: Divide and Conquer",
                 font=("Helvetica", 16, "italic"),
                 bg=self.colors['bg'], fg=self.colors['highlight']).pack()
        tk.Label(header, text="DIVIDE  \u2192  CONQUER  \u2192  COMBINE",
                 font=("Helvetica", 13),
                 bg=self.colors['bg'], fg=self.colors['text']).pack(pady=6)
        btns = tk.Frame(frame, bg=self.colors['bg'])
        btns.pack(pady=40)
        bstyle = dict(font=("Helvetica", 16, "bold"),
                      width=25, height=2, bd=0, cursor="hand2")
        tk.Button(btns, text="\U0001f1ec\U0001f1e7  ENGLISH VERSION",
                  bg=self.colors['accent1'], fg="white",
                  activebackground="#c0392b", activeforeground="white",
                  command=lambda: self.start_game("english"),
                  **bstyle).pack(pady=10)
        tk.Button(btns, text="\U0001f1ea\U0001f1fa  EUROPEAN VERSION",
                  bg=self.colors['accent2'], fg="white",
                  activebackground="#2980b9", activeforeground="white",
                  command=lambda: self.start_game("european"),
                  **bstyle).pack(pady=10)
        tk.Button(btns, text="\u274c  EXIT",
                  bg=self.colors['accent3'], fg="white",
                  activebackground="#27ae60", activeforeground="white",
                  command=self.root.quit,
                  **bstyle).pack(pady=10)
        tk.Label(frame,
                 text="Recursive Sub-problem Decomposition  \u2022  "
                      "Transposition Table  \u2022  BFS + DFS Conquer",
                 font=("Helvetica", 10),
                 bg=self.colors['bg'], fg=self.colors['text']
                 ).pack(side="bottom", pady=20)
    def start_game(self, version: str) -> None:
        self.clear_window()
        self.current_frame = GameFrame(
            self.root, version, self.show_main_menu, self.colors)
        self.current_frame.pack(fill="both", expand=True)
if __name__ == "__main__":
    root = tk.Tk()
    try:
        root.iconbitmap(default='icon.ico')
    except Exception:
        pass
    app = PegSolitaireApp(root)
    root.update_idletasks()
    w = root.winfo_width()
    h = root.winfo_height()
    x = (root.winfo_screenwidth()  // 2) - (w // 2)
    y = (root.winfo_screenheight() // 2) - (h // 2)
    root.geometry(f'{w}x{h}+{x}+{y}')
    root.mainloop()
